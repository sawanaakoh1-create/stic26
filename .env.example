# ============================================================
#  AfriVoice AI — variables d'environnement locales
# ============================================================
#  1. Duplique ce fichier en `.env.local` (déjà ignoré par git)
#  2. Colle ton token Hugging Face à la ligne HUGGINGFACE_TOKEN
#  3. Redémarre `npm run dev`
# ============================================================

# Backend FastAPI (facultatif — laisser vide pour utiliser l'API /api/voice)
NEXT_PUBLIC_AFRIVOICE_API_URL=

# Token Hugging Face (Read). Créé sur https://huggingface.co/settings/tokens
# Utilisé côté serveur uniquement — jamais exposé au navigateur.
HUGGINGFACE_TOKEN=

# Modèles Hugging Face utilisés par /api/voice (surchargeable)
HF_ASR_MODEL_PRIMARY=facebook/mms-1b-all
HF_ASR_MODEL_FALLBACK=openai/whisper-large-v3
HF_TTS_MODEL=facebook/mms-tts-mos
HF_TARGET_LANGUAGE=mos
HF_ASR_FALLBACK_LANGUAGE=french
